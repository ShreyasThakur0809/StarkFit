# StarkFit Environment Variables

# Starknet Contract
NEXT_PUBLIC_STARKFIT_CONTRACT_ADDRESS=0x0
NEXT_PUBLIC_STARKNET_NETWORK=sepolia

# AVNU Paymaster (for gasfree/sponsored mode)
NEXT_PUBLIC_AVNU_API_KEY=

# Oracle (backend signer for step verification)
ORACLE_PRIVATE_KEY=
ORACLE_ADDRESS=
STARKNET_RPC=https://starknet-sepolia.public.blastapi.io

# Google Fit OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
